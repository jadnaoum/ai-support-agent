# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support_agent
DATABASE_URL_SYNC=postgresql+pg8000://postgres:postgres@localhost:5432/support_agent

# LLM — via LiteLLM (never import provider SDKs directly)
LITELLM_MODEL=claude-sonnet-4-6
LITELLM_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Environment (set to "test" to enable /api/chat/test endpoint for evals)
APP_ENV=development

# Agent config
CONFIDENCE_THRESHOLD=0.7
MAX_CONTEXT_MESSAGES=50
MESSAGE_RETENTION_DAYS=60

# LangSmith tracing (optional — set LANGCHAIN_TRACING_V2=true to enable)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=ai-support-agent
LANGCHAIN_TRACING_V2=false
